# Nebius Cloud GPU instance connection settings
# Copy this file to .env and fill in your values

# Public IP of the Nebius GPU instance (shown in Nebius Console → Compute → Instances)
NEBIUS_INSTANCE_IP=

# SSH username for the instance (typically "ubuntu" for Nebius Ubuntu images)
NEBIUS_SSH_USER=ubuntu

# Absolute path to the SSH private key paired with the key you uploaded to Nebius
NEBIUS_SSH_KEY_PATH=~/.ssh/id_rsa

# Remote directory where the repo will be copied and run
NEBIUS_REMOTE_DIR=/home/ubuntu/gpu_and_inference_hw

# (Optional) SSH port — Nebius default is 22
NEBIUS_SSH_PORT=22
