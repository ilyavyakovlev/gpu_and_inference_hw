# Nebius Cloud GPU instance connection settings
# Copy this file to .env and fill in your values.

# Public IP of the most recently created instance.
# Automatically updated by nebius_create_and_run.sh; set manually for run_on_nebius.sh.
NEBIUS_INSTANCE_IP=

NEBIUS_SSH_USER=karke
NEBIUS_SSH_KEY_PATH=~/.ssh/id_ed25519
NEBIUS_SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
NEBIUS_REMOTE_DIR=/home/karke/gpu_and_inference_hw
NEBIUS_SSH_PORT=22

# ── Nebius project / network (needed by nebius_create_and_run.sh) ──────────
# Find these in Nebius Console → your project → Settings / Subnets
NEBIUS_PROJECT_ID=
NEBIUS_SUBNET_ID=

# ── VM sizing (defaults match the recommended config) ──────────────────────
NEBIUS_GPU_PLATFORM=gpu-h100-sxm
NEBIUS_INSTANCE_PRESET=1gpu-16vcpu-200gb
NEBIUS_DISK_SIZE_BYTES=214748364800
